{
  "version": 2,
  "builds": [
    {
      "src": "angular-frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/angular-frontend/browser" }
    },
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/app.py"
    },
    {
      "src": "/(.*)",
      "dest": "angular-frontend/$1",
      "check": true
    }
  ]
}